{
  "name": "clickflow",
  "version": "0.1.0",
  "description": "ClickFlow — минималистичный кроссплатформенный кликер и визуальный автоматизатор (Electron, simulation-only beta).",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "smoke": "node scripts/smoke-check.js"
  },
  "keywords": [
    "clickflow",
    "electron",
    "automation",
    "simulation",
    "desktop",
    "beta"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Citrus-cloud/Mine.git"
  },
  "build": {
    "appId": "com.clickflow.app",
    "productName": "ClickFlow",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  }
}
